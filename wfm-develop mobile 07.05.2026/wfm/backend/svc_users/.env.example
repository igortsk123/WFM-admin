# Database
DATABASE_URL=postgresql://wfm_user:wfm_password@postgres:5432/wfm_users

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True
LOG_LEVEL=INFO
HTTPX_LOG_LEVEL=WARNING  # DEBUG для детальных HTTP логов (запросы к SSO)

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT Authentication (Beyond Violet)
# Ключ размещается в shared/bv_public_key.pem (загружается автоматически)
# Опционально можно переопределить через переменные окружения:
# BV_PUBLIC_KEY=<прямое значение ключа>
# BV_PUBLIC_KEY_PATH=/path/to/key.pem
# JWT_CLOCK_SKEW=60

# SSO Integration (Beyond Violet)
SSO_BASE_URL=https://api.beyondviolet.com/sys/v1
SSO_TIMEOUT=5
SSO_CACHE_TTL=86400
