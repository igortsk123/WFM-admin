# svc_notifications — пример переменных окружения

DATABASE_URL=postgresql://wfm_notifications_user:wfm_notifications_password@localhost:5432/wfm_notifications
DEBUG=True
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT (тот же публичный ключ, что у других сервисов)
BV_PUBLIC_KEY=<публичный ключ>

# Firebase Admin SDK (JSON-строка или путь к файлу)
FIREBASE_CREDENTIALS_JSON=<json строка из serviceAccountKey.json>

# Таймаут ACK для WebSocket (секунды)
WS_ACK_TIMEOUT=5

# Межсервисное взаимодействие
USERS_SERVICE_URL=http://svc_users:8000
USERS_SERVICE_TIMEOUT=5

# Huawei Push Kit (HMS) — из agconnect-services.json
# Оставить пустыми, если HMS не используется
HMS_APP_ID=<app_id из agconnect-services.json>
HMS_CLIENT_SECRET=<client_secret из agconnect-services.json>
