          "id": "o8dcZQsMua42to6t",
          "name": "users"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "function csvField(value) {\n  if (value === null || value === undefined) return '';\n  const s = String(value);\n  if (s.includes(',') || s.includes('\"') || s.includes('\\n')) {\n    return '\"' + s.replace(/\"/g, '\"\"') + '\"';\n  }\n  return s;\n}\n\nconst rows = $input.all().map(i => i.json);\nconst lines = ['id,name,address'];\nfor (const r of rows) {\n  let name, address;\n  if (r.address) {\n    name = r.name;\n    address = r.address;\n  } else {\n    name = 'Магазин ' + r.id;\n    address = r.name;\n  }\n  lines.push(r.id + ',' + csvField(name) + ',' + csvField(address));\n}\nconst csv = lines.join('\\n');\n\nconst data = await this.helpers.prepareBinaryData(\n  Buffer.from(csv, 'utf-8'),\n  'stores.csv',\n  'text/csv'\n);\nreturn [{ json: {}, binary: { data } }];"
      },
      "id": "ref-0005",
      "name": "Сформировать stores.csv",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 120]
    },
    {
      "parameters": {
        "jsCode": "function field(value) {\n  if (value === null || value === undefined) return 'NULL';\n  return '\"' + String(value).replace(/\"/g, '\"\"') + '\"';\n}\n\nconst rows = $input.all().map(i => i.json);\nconst lines = ['\"id\",\"first_name\",\"last_name\",\"middle_name\"'];\nfor (const r of rows) {\n  lines.push('\"' + r.id + '\",' + field(r.first_name) + ',' + field(r.last_name) + ',' + field(r.middle_name));\n}\nconst csv = lines.join('\\n');\n\nconst data = await this.helpers.prepareBinaryData(\n  Buffer.from(csv, 'utf-8'),\n  'users.csv',\n  'text/csv'\n);\nreturn [{ json: {}, binary: { data } }];"
      },
