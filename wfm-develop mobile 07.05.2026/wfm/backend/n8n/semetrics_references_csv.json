        "jsCode": "function csvField(value) {\n  if (value === null || value === undefined) return '';\n  const s = String(value);\n  if (s.includes(',') || s.includes('\"') || s.includes('\\n')) {\n    return '\"' + s.replace(/\"/g, '\"\"') + '\"';\n  }\n  return s;\n}\n\nconst rows = $input.all().map(i => i.json);\nconst lines = ['user_id,store_id,valid_from,valid_to,role'];\nfor (const r of rows) {\n  lines.push(\n    csvField(r.user_id) + ',' +\n    csvField(r.store_id) + ',' +\n    csvField(r.valid_from) + ',' +\n    csvField(r.valid_to) + ',' +\n    csvField(r.role)\n  );\n}\nconst csv = lines.join('\\n');\n\nconst data = await this.helpers.prepareBinaryData(\n  Buffer.from(csv, 'utf-8'),\n  'assignments.csv',\n  'text/csv'\n);\nreturn [{ json: {}, binary: { data } }];"
      },
