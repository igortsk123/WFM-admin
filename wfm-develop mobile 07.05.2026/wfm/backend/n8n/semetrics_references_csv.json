    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  u.id,\n  COALESCE(lc.first_name, u.first_name, sc.first_name) AS first_name,\n  COALESCE(lc.last_name, u.last_name, sc.last_name) AS last_name,\n  COALESCE(lc.middle_name, u.middle_name, sc.middle_name) AS middle_name\nFROM users u\nLEFT JOIN user_lama_cache lc ON lc.user_id = u.id\nLEFT JOIN user_sso_cache sc ON sc.user_id = u.id\nORDER BY u.id",
        "options": {}
      },
      "id": "ref-0004",
      "name": "Пользователи из БД",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [900, 480],
      "credentials": {
