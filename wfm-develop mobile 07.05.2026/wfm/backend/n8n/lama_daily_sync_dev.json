{
  "name": "LAMA Daily Sync — DEV",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 6,
              "triggerAtMinute": 0
            }
          ]
        }
      },
      "id": "cron-trigger",
      "name": "Каждый день в 6:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://svc_tasks:8000/internal/sync-daily",
        "options": {
          "timeout": 300000
        }
      },
      "id": "http-sync",
      "name": "Запустить синхронизацию",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://svc_tasks:8000/internal/clear-external-ids",
        "options": {
          "timeout": 30000
        }
      },
      "id": "http-clear",
      "name": "Очистить external_id",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [680, 300]
    }
  ],
  "connections": {
    "Каждый день в 6:00": {
      "main": [
        [
          {
            "node": "Запустить синхронизацию",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Запустить синхронизацию": {
      "main": [
        [
          {
            "node": "Очистить external_id",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  }
}
