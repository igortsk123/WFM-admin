// Скопируй в secrets.h и заполни своими данными.
// secrets.h добавлен в .gitignore — в репозиторий не попадёт.

#pragma once

// WiFi-сети (перебираются по порядку, приоритет у первой)
#define WIFI_NETWORKS \
    { "HomeSSID", "homepass" }, \
    { "OfficeSSID", "officepass" }

// WebSocket сервер svc_monitoring (WFM)
// dev:  dev.wfm.beyondviolet.com
// prod: wfm.beyondviolet.com
#define WS_HOST  "dev.wfm.beyondviolet.com"
#define WS_PORT  443
#define WS_PATH  "/monitoring/api/events/ws"
#define WS_TOKEN "your-device-token"   // должен совпадать с DEVICE_TOKEN в .env svc_monitoring

// GPIO пьезо-бузера (или -1 если не подключён)
#define BUZZER_PIN -1
