# =============================================================================
# WFM Backend — переменные окружения
# Скопировать в .env и заполнить значениями для своего окружения
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=root
POSTGRES_PASSWORD=changeme
WFM_TASKS_DB_PASSWORD=wfm_tasks_password
WFM_USERS_DB_PASSWORD=wfm_users_password
WFM_SHIFTS_DB_PASSWORD=wfm_shifts_password

# --- Database URLs ---
TASKS_DATABASE_URL=postgresql://wfm_tasks_user:wfm_tasks_password@postgres:5432/wfm_tasks
USERS_DATABASE_URL=postgresql://wfm_users_user:wfm_users_password@postgres:5432/wfm_users
SHIFTS_DATABASE_URL=postgresql://wfm_shifts_user:wfm_shifts_password@postgres:5432/wfm_shifts

# --- Приложение ---
DEBUG=False
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- LAMA Integration (все сервисы) ---
LAMA_API_BASE_URL=https://wfm-smart.lama70.ru/api/
LAMA_API_TIMEOUT=5
LAMA_API_ENABLED=true
LAMA_CACHE_TTL=3600

# --- Межсервисное взаимодействие ---
SHIFTS_SERVICE_URL=http://svc_shifts:8000
SHIFTS_SERVICE_TIMEOUT=5
USERS_SERVICE_URL=http://svc_users:8000
USERS_SERVICE_TIMEOUT=5

# --- SSO (svc_users) ---
SSO_BASE_URL=https://api.beyondviolet.com/sys/v1
SSO_TIMEOUT=5
SSO_CACHE_TTL=86400
HTTPX_LOG_LEVEL=WARNING

# --- S3 (RegRU, бакет wfm-images) ---
S3_ENDPOINT_URL=https://s3.regru.cloud
S3_ACCESS_KEY=<ключ из панели RegRU>
S3_SECRET_KEY=<секрет из панели RegRU>
S3_BUCKET_NAME=wfm-images
S3_PUBLIC_URL_PREFIX=https://wfm-images.website.regru.cloud

# --- JWT Authentication (Beyond Violet) ---
# Публичный ключ RS256 для валидации JWT токенов
# ВАЖНО: Для многострочного ключа используйте одну из опций:
#
# Опция 1 (рекомендуется): Обернуть в кавычки с сохранением переносов строк
# BV_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
# MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA3iIO+7nH/fNh9xbgQxg9
# ...
# -----END PUBLIC KEY-----"
#
# Опция 2: Заменить переносы строк на \n (одна строка)
# BV_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjAN...\n-----END PUBLIC KEY-----"
#
BV_PUBLIC_KEY=

# --- n8n (только для dev/local) ---
N8N_DB_PASSWORD=Pakar602
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=testA1234
N8N_HOST=localhost
N8N_ENCRYPTION_KEY=
N8N_LICENSE_ACTIVATION_KEY=
N8N_WEBHOOK_URL=http://localhost:5678

# --- PostgreSQL порт (только для local) ---
POSTGRES_PORT=5432
