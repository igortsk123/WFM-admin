# Database
DATABASE_URL=postgresql://wfm_user:wfm_password@postgres:5432/wfm_tasks

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True
LOG_LEVEL=INFO

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT Authentication (Beyond Violet)
# Ключ размещается в shared/bv_public_key.pem (загружается автоматически)
# Опционально можно переопределить через переменные окружения:
# BV_PUBLIC_KEY=<прямое значение ключа>
# BV_PUBLIC_KEY_PATH=/path/to/key.pem
# JWT_CLOCK_SKEW=60

# S3 (RegRU, бакет wfm-images)
S3_ENDPOINT_URL=https://s3.regru.cloud
S3_ACCESS_KEY=<ключ из панели RegRU>
S3_SECRET_KEY=<секрет из панели RegRU>
S3_BUCKET_NAME=wfm-images
S3_PUBLIC_URL_PREFIX=https://wfm-images.website.regru.cloud
