# ──────────────────────────────────────────────────────────────────────
# WFM Admin — env config
# Скопируй в .env.local (не коммитится) и заполни.
# ──────────────────────────────────────────────────────────────────────

# Базовый URL real backend (FastAPI микросервисы за nginx).
# DEV:  https://dev.wfm.beyondviolet.com
# PROD: https://wfm.beyondviolet.com
# Local docker-compose: см. backend/docker-compose.yml (порты 8000/8001/8003/8004)
NEXT_PUBLIC_API_BASE_URL=https://dev.wfm.beyondviolet.com

# Включить real backend вместо моков.
# Если false — admin живёт на lib/mock-data/ и работает offline.
# При true — обязательно нужен валидный JWT в localStorage (см. dev-helper).
NEXT_PUBLIC_USE_REAL_API=false
